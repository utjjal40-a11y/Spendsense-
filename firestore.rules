rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation patterns
    function isValidTransaction(data) {
      let requiredFields = ['type', 'amount', 'description', 'category', 'date'];
      return data.keys().hasAll(requiredFields) &&
             data.type in ['income', 'expense'] &&
             data.amount is number &&
             data.description is string && data.description.size() <= 1000 &&
             data.category is string &&
             data.date is string;
    }

    function isValidMessage(data) {
      let requiredFields = ['from', 'text', 'timestamp'];
      return data.keys().hasAll(requiredFields) &&
             data.from in ['bot', 'user'] &&
             data.text is string && data.text.size() <= 10000 &&
             data.timestamp is number;
    }

    function isValidConfig(data) {
      // Configuration can contain any of these keys
      let allowedKeys = ['categoryBudgets', 'monthlyIncome', 'totalDebt', 'emergencyFund', 'goals'];
      return data.keys().hasAny(allowedKeys);
    }

    // User collection gate
    match /users/{userId} {
      allow get: if isOwner(userId);
      
      match /transactions/{transactionId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidTransaction(incoming());
        allow update: if isOwner(userId) && isValidTransaction(incoming()) && 
                        incoming().userId == existing().userId;
        allow delete: if isOwner(userId);
      }

      match /messages/{messageId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(incoming());
        allow update: if false; // messages immutable
        allow delete: if isOwner(userId);
      }

      match /config/{configId} {
        allow get: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidConfig(incoming());
        allow delete: if isOwner(userId);
      }
    }
  }
}
